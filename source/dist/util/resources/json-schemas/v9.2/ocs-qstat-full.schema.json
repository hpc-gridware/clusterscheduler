{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://raw.githubusercontent.com/hpc-gridware/clusterscheduler/master/source/dist/util/resources/json-schemas/v9.2/ocs-qstat-full.schema.json",
   "title": "OCS/GCS qstat full schema",
   "description": "Schema describing qstat full output (-f). Additional task information may be present with -t, request information with -r, queue resource information with -F, queue explanations with -explain, and extended job attributes with switches such as -ext, -urg, and -pri.",
   "type": "object",
   "required": [
      "queues"
   ],
   "additionalProperties": true,
   "$defs": {
      "queueResources": {
         "type": "object",
         "description": "Queue resource attributes as reported by `qstat -f -F`. Standard resources are always present; additional cluster-specific resources may appear as extra properties.",
         "required": [
            "load_avg",
            "load_short",
            "load_medium",
            "load_long",
            "arch",
            "num_proc",
            "mem_free",
            "swap_free",
            "virtual_free",
            "mem_total",
            "swap_total",
            "virtual_total",
            "mem_used",
            "swap_used",
            "virtual_used",
            "cpu",
            "m_topology",
            "m_socket",
            "m_core",
            "m_thread",
            "np_load_avg",
            "np_load_short",
            "np_load_medium",
            "np_load_long",
            "slots",
            "qname",
            "hostname",
            "tmpdir",
            "seq_no",
            "rerun",
            "calendar",
            "s_rt",
            "h_rt",
            "s_cpu",
            "h_cpu",
            "s_fsize",
            "h_fsize",
            "s_data",
            "h_data",
            "s_stack",
            "h_stack",
            "s_core",
            "h_core",
            "s_rss",
            "h_rss",
            "s_vmem",
            "h_vmem",
            "min_cpu_interval"
         ],
         "properties": {
            "load_avg": { "type": "number", "description": "Normalized load average." },
            "load_short": { "type": "number", "description": "Short-term load average." },
            "load_medium": { "type": "number", "description": "Medium-term load average." },
            "load_long": { "type": "number", "description": "Long-term load average." },
            "arch": { "type": "string", "description": "Architecture string of the execution host." },
            "num_proc": { "type": "integer", "minimum": 0, "description": "Number of processors." },
            "mem_free": { "type": "number", "description": "Free memory." },
            "swap_free": { "type": "number", "description": "Free swap space." },
            "virtual_free": { "type": "number", "description": "Free virtual memory." },
            "mem_total": { "type": "number", "description": "Total memory." },
            "swap_total": { "type": "number", "description": "Total swap space." },
            "virtual_total": { "type": "number", "description": "Total virtual memory." },
            "mem_used": { "type": "number", "description": "Used memory." },
            "swap_used": { "type": "number", "description": "Used swap space." },
            "virtual_used": { "type": "number", "description": "Used virtual memory." },
            "cpu": { "type": "number", "description": "CPU utilization value." },
            "m_topology": { "type": "string", "description": "Topology string describing the CPU layout." },
            "m_socket": { "type": "integer", "minimum": 0, "description": "Socket count or socket-related topology value." },
            "m_core": { "type": "integer", "minimum": 0, "description": "Core count or core-related topology value." },
            "m_thread": { "type": "integer", "minimum": 0, "description": "Thread count or thread-related topology value." },
            "np_load_avg": { "type": "number", "description": "Normalized per-processor load average." },
            "np_load_short": { "type": "number", "description": "Short-term normalized per-processor load." },
            "np_load_medium": { "type": "number", "description": "Medium-term normalized per-processor load." },
            "np_load_long": { "type": "number", "description": "Long-term normalized per-processor load." },
            "slots": { "type": "integer", "minimum": 0, "description": "Configured number of slots." },
            "qname": { "$ref": "./ocs-qstat-common.schema.json#/$defs/clusterQueueName" },
            "hostname": { "$ref": "./ocs-qstat-common.schema.json#/$defs/hostname" },
            "tmpdir": { "type": "string", "minLength": 1, "description": "Temporary directory used for job execution." },
            "seq_no": { "type": "integer", "minimum": 0, "description": "Sequence number of the queue." },
            "rerun": { "type": "boolean", "description": "Indicates whether rerun is enabled." },
            "calendar": { "type": "string", "description": "Associated calendar name or `NONE` if no calendar is configured.", "examples": ["NONE"] },
            "s_rt": { "type": "number", "description": "Soft runtime limit." },
            "h_rt": { "type": "number", "description": "Hard runtime limit." },
            "s_cpu": { "type": "number", "description": "Soft CPU time limit." },
            "h_cpu": { "type": "number", "description": "Hard CPU time limit." },
            "s_fsize": { "type": "number", "description": "Soft file size limit." },
            "h_fsize": { "type": "number", "description": "Hard file size limit." },
            "s_data": { "type": "number", "description": "Soft data segment size limit." },
            "h_data": { "type": "number", "description": "Hard data segment size limit." },
            "s_stack": { "type": "number", "description": "Soft stack size limit." },
            "h_stack": { "type": "number", "description": "Hard stack size limit." },
            "s_core": { "type": "number", "description": "Soft core file size limit." },
            "h_core": { "type": "number", "description": "Hard core file size limit." },
            "s_rss": { "type": "number", "description": "Soft resident set size limit." },
            "h_rss": { "type": "number", "description": "Hard resident set size limit." },
            "s_vmem": { "type": "number", "description": "Soft virtual memory limit." },
            "h_vmem": { "type": "number", "description": "Hard virtual memory limit." },
            "min_cpu_interval": { "type": "integer", "minimum": 0, "description": "Minimum CPU accounting interval." }
         },
         "additionalProperties": {
            "$ref": "./ocs-qstat-common.schema.json#/$defs/scalarValue"
         }
      },

      "runningJob": {
         "allOf": [
            {
               "$ref": "./ocs-qstat-common.schema.json#/$defs/runningJobBase"
            },
            {
               "type": "object",
               "properties": {
                  "parallel_task": {
                     "type": "array",
                     "description": "Active parallel environment (PE) tasks of a tightly integrated parallel job.",
                     "items": {
                        "$ref": "./ocs-qstat-common.schema.json#/$defs/parallelTask"
                     }
                  },
                  "global_hard_request": {
                     "type": "array",
                     "description": "Global hard resource requests of the job.",
                     "items": {
                        "$ref": "./ocs-qstat-common.schema.json#/$defs/resourceRequestWithContribution"
                     }
                  },
                  "default_hard_request": {
                     "type": "array",
                     "description": "Default hard resource requests applied to the job.",
                     "items": {
                        "$ref": "./ocs-qstat-common.schema.json#/$defs/resourceRequestDefault"
                     }
                  },
                  "requested_pe": {
                     "$ref": "./ocs-qstat-common.schema.json#/$defs/requestedPe"
                  },
                  "granted_pe": {
                     "$ref": "./ocs-qstat-common.schema.json#/$defs/grantedPe"
                  }
               },
               "additionalProperties": true
            }
         ]
      },

      "pendingJob": {
         "$ref": "./ocs-qstat-common.schema.json#/$defs/pendingJobBase"
      },

      "queueInstance": {
         "type": "object",
         "required": [
            "name",
            "qtype",
            "slots_used",
            "slots_resv",
            "slots_total",
            "load_avg",
            "arch",
            "state"
         ],
         "properties": {
            "name": {
               "$ref": "./ocs-qstat-common.schema.json#/$defs/queueInstanceName"
            },
            "qtype": {
               "$ref": "./ocs-qstat-common.schema.json#/$defs/qtype"
            },
            "slots_used": {
               "type": "integer",
               "minimum": 0,
               "description": "Number of slots currently in use."
            },
            "slots_resv": {
               "type": "integer",
               "minimum": 0,
               "description": "Number of reserved slots."
            },
            "slots_total": {
               "type": "integer",
               "minimum": 0,
               "description": "Total number of slots available in the queue."
            },
            "load_avg": {
               "type": "number",
               "description": "Current load average of the execution host."
            },
            "arch": {
               "type": "string",
               "description": "Architecture string of the execution host."
            },
            "state": {
               "$ref": "./ocs-qstat-common.schema.json#/$defs/queueState"
            },
            "message": {
               "type": "string",
               "description": "Optional status message describing the queue state, returned when `-explain` is used."
            },
            "queue_resources": {
               "$ref": "#/$defs/queueResources"
            },
            "jobs_running": {
               "type": "array",
               "description": "Jobs currently active in the queue, including running and suspended jobs.",
               "items": {
                  "$ref": "#/$defs/runningJob"
               }
            }
         },
         "additionalProperties": false
      }
   },
   "properties": {
      "queues": {
         "type": "array",
         "description": "List of queue instances after applying optional filters such as `-q`, `-pe`, `-l`, and `-qs`.",
         "items": {
            "$ref": "#/$defs/queueInstance"
         }
      },
      "jobs_pending": {
         "type": "array",
         "description": "Jobs that are pending and not yet running on any queue.",
         "items": {
            "$ref": "#/$defs/pendingJob"
         }
      }
   }
}