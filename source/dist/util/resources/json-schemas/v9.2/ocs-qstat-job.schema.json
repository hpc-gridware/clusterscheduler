{
   "$schema": "https://json-schema.org/draft/2020-12/schema",
   "$id": "https://raw.githubusercontent.com/hpc-gridware/clusterscheduler/master/source/dist/util/resources/json-schemas/v9.2/ocs-qstat-job.schema.json",
   "title": "OCS qstat job JSON output",
   "description": "Schema for qstat -fmt json -j job output generated by QStatJobViewJSON.",
   "type": "object",
   "additionalProperties": true,
   "required": ["jobs"],
   "properties": {
      "jobs": {
         "type": "array",
         "items": { "$ref": "#/$defs/job" }
      }
   },
   "$defs": {
      "hostname": {
         "description": "Hostname or FQDN without wildcard or pattern characters.",
         "type": "string",
         "minLength": 1,
         "maxLength": 253,
         "pattern": "^[A-Za-z0-9.-]+$"
      },
      "hostname_or_pattern": {
         "description": "Hostname, FQDN or fnmatch-style pattern used in HPC environments.",
         "type": "string",
         "minLength": 1,
         "maxLength": 253,
         "pattern": "^[A-Za-z0-9._*?\\[\\]!^-]+$"
      },
      "path": {
         "description": "Filesystem path (absolute, relative or variable-expanded).",
         "type": "string",
         "minLength": 1
      },
      "timestamp": {
         "type": "string",
         "format": "date-time"
      },
      "path_entry": {
         "type": "object",
         "additionalProperties": true,
         "required": ["host", "file_host", "path", "file_staging"],
         "properties": {
            "host": { "$ref": "#/$defs/hostname" },
            "file_host": {
               "description": "File staging host. May be empty if file staging is not used.",
               "anyOf": [
                  { "type": "string", "maxLength": 0 },
                  { "$ref": "#/$defs/hostname" }
               ]
            },
            "path": { "$ref": "#/$defs/path" },
            "file_staging": { "type": "boolean" }
         }
      },
      "name_value_string": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name"],
         "properties": {
            "name": { "type": "string" },
            "value": { "type": "string" }
         }
      },
      "resource_request": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name", "value"],
         "properties": {
            "name": { "type": "string" },
            "value": {
               "anyOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "boolean" },
                  { "type": "object" },
                  { "type": "array" },
                  { "type": "null" }
               ]
            }
         }
      },
      "ownership": {
         "type": "object",
         "additionalProperties": true,
         "required": ["primary", "supplementary"],
         "properties": {
            "primary": {
               "type": "object",
               "additionalProperties": true,
               "required": ["owner", "uid", "group", "gid"],
               "properties": {
                  "owner": { "type": "string" },
                  "uid": { "type": "integer", "minimum": 0 },
                  "group": { "type": "string" },
                  "gid": { "type": "integer", "minimum": 0 }
               }
            },
            "supplementary": {
               "type": "array",
               "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["name", "id"],
                  "properties": {
                     "name": { "type": "string" },
                     "id": { "type": "integer", "minimum": 0 }
                  }
               }
            }
         }
      },
      "checkpoint": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name", "attr", "interval"],
         "properties": {
            "name": { "type": "string" },
            "attr": { "type": "string" },
            "interval": { "type": "integer", "minimum": 0 }
         }
      },
      "path_alias": {
         "type": "object",
         "additionalProperties": true,
         "required": ["src_path", "submit_host", "exec_host", "dst_path"],
         "properties": {
            "src_path": { "$ref": "#/$defs/path" },
            "submit_host": { "$ref": "#/$defs/hostname_or_pattern" },
            "exec_host": { "$ref": "#/$defs/hostname_or_pattern" },
            "dst_path": { "$ref": "#/$defs/path" }
         }
      },
      "mail_recipient": {
         "type": "object",
         "additionalProperties": true,
         "required": ["user", "host"],
         "properties": {
            "user": { "type": "string" },
            "host": { "$ref": "#/$defs/hostname" }
         }
      },
      "shell": {
         "type": "object",
         "additionalProperties": true,
         "required": ["path", "host"],
         "properties": {
            "path": { "$ref": "#/$defs/path" },
            "host": { "$ref": "#/$defs/hostname" }
         }
      },
      "pe": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name", "range"],
         "properties": {
            "name": { "type": "string" },
            "range": { "type": "string" }
         }
      },
      "job_array_tasks": {
         "type": "object",
         "additionalProperties": true,
         "required": ["start", "end", "step"],
         "properties": {
            "start": { "type": "integer" },
            "end": { "type": "integer" },
            "step": { "type": "integer" }
         }
      },
      "binding": {
         "type": "object",
         "additionalProperties": true,
         "required": ["bstrategy", "amount", "bunit", "btype", "bfilter", "bsort", "bstart", "bstop", "binstance"],
         "properties": {
            "bstrategy": { "type": "string" },
            "amount": { "type": "integer" },
            "bunit": { "type": "string" },
            "btype": { "type": "string" },
            "bfilter": { "type": "string" },
            "bsort": { "type": "string" },
            "bstart": { "type": "string" },
            "bstop": { "type": "string" },
            "binstance": { "type": "string" }
         }
      },
      "exec_host": {
         "type": "object",
         "additionalProperties": true,
         "required": ["hostname", "slots"],
         "properties": {
            "hostname": { "$ref": "#/$defs/hostname" },
            "slots": { "type": "integer", "minimum": 0 }
         }
      },
      "granted_queue": {
         "type": "object",
         "additionalProperties": true,
         "required": ["queue_name", "slots"],
         "properties": {
            "queue_name": {
               "type": "string",
               "pattern": "^[^@]+@[^@]+$"
            },
            "slots": { "type": "integer", "minimum": 0 }
         }
      },
      "exec_binding": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name", "binding"],
         "properties": {
            "name": { "$ref": "#/$defs/hostname" },
            "binding": {
               "type": "array",
               "items": { "type": "string" }
            }
         }
      },
      "resource_map": {
         "type": "object",
         "additionalProperties": true,
         "required": ["name", "hostname", "rsmap_ids", "total_amount"],
         "properties": {
            "name": { "type": "string" },
            "hostname": { "$ref": "#/$defs/hostname" },
            "rsmap_ids": {
               "type": "array",
               "items": { "type": "string" }
            },
            "total_amount": { "type": "integer", "minimum": 0 }
         }
      },
      "usage": {
         "type": "object",
         "additionalProperties": true,
         "properties": {
            "wallclock": { "type": "number" },
            "cpu": { "type": "number" },
            "mem": { "type": "number" },
            "io": { "type": "number" },
            "ioops": { "type": "number" },
            "iow": { "type": "number" },
            "vmem": { "type": "number" },
            "maxvmem": { "type": "number" },
            "maxrss": { "type": "number" },
            "pss": { "type": "number" },
            "maxpss": { "type": "number" },
            "pmem": { "type": "number" },
            "smem": { "type": "number" }
         }
      },
      "task": {
         "type": "object",
         "additionalProperties": true,
         "properties": {
            "task_id": { "type": "integer" },
            "job_state": {
               "type": "string",
               "pattern": "^[A-Za-z]{1,6}$"
            },
            "usage": { "$ref": "#/$defs/usage" },
            "exec_binding_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/exec_binding" }
            },
            "granted_queue_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/granted_queue" }
            },
            "exec_host_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/exec_host" }
            },
            "start_time": { "$ref": "#/$defs/timestamp" },
            "resource_map": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_map" }
            },
            "error_reason": {
               "type": "array",
               "items": { "type": "string" }
            }
         }
      },
      "job": {
         "type": "object",
         "additionalProperties": true,
         "required": ["job_number"],
         "properties": {
            "job_number": {
               "type": "integer",
               "minimum": 1
            },
            "category_id": {
               "type": "integer",
               "minimum": 0
            },
            "exec_file": { "$ref": "#/$defs/path" },
            "cwd": { "$ref": "#/$defs/path" },
            "script_file": { "$ref": "#/$defs/path" },
            "script_ptr": { "$ref": "#/$defs/path" },
            "submission_time": { "$ref": "#/$defs/timestamp" },
            "submit_cmd_line": { "type": "string" },
            "effective_submit_cmd_line": { "type": "string" },
            "ownership": { "$ref": "#/$defs/ownership" },
            "environment_core": {
               "type": "array",
               "items": { "$ref": "#/$defs/name_value_string" }
            },
            "account": { "type": "string" },
            "checkpoint": { "$ref": "#/$defs/checkpoint" },
            "reserve": { "type": "boolean" },
            "merge_stderr": { "type": "boolean" },
            "hard_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "soft_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "hard_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "soft_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "master_hard_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "master_soft_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "slave_hard_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "slave_soft_queue_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "mail_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/mail_recipient" }
            },
            "notify": { "type": "boolean" },
            "job_name": { "type": "string" },
            "priority": { "type": "number" },
            "job_share": { "type": "number" },
            "restart": { "type": "boolean" },
            "env_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/name_value_string" }
            },
            "verify": { "type": "integer" },
            "job_args": {
               "type": "array",
               "items": { "type": "string" }
            },
            "script_size": {
               "type": "integer",
               "minimum": 0
            },
            "pe": { "$ref": "#/$defs/pe" },
            "verify_suitable_queues": { "type": "integer" },
            "version": { "type": "integer" },
            "override_tickets": { "type": "number" },
            "ar_id": {
               "type": "integer",
               "minimum": 0
            },
            "department": { "type": "string" },
            "sync_options": { "type": "string" },
            "job_array_tasks": { "$ref": "#/$defs/job_array_tasks" },
            "task_concurrency": {
               "type": "integer",
               "minimum": 0
            },
            "binding": { "$ref": "#/$defs/binding" },
            "array_tasks": {
               "type": "array",
               "items": { "$ref": "#/$defs/task" }
            },
            "scheduling_info": {
               "type": "array",
               "items": { "type": "string" }
            },
            "stdin_path_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/path_entry" }
            },
            "stdout_path_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/path_entry" }
            },
            "stderr_path_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/path_entry" }
            },
            "path_aliases": {
               "type": "array",
               "items": { "$ref": "#/$defs/path_alias" }
            },
            "shell_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/shell" }
            },
            "deadline_time": { "$ref": "#/$defs/timestamp" },
            "execution_time": { "$ref": "#/$defs/timestamp" },
            "soft_wallclock_gmt": { "$ref": "#/$defs/timestamp" },
            "hard_wallclock_gmt": { "$ref": "#/$defs/timestamp" },
            "directive_prefix": { "type": "string" },
            "mail_options": { "type": "string" },
            "project": { "type": "string" },
            "jid_predecessor_list": {
               "type": "array",
               "items": { "type": "integer" }
            },
            "jid_successor_list": {
               "type": "array",
               "items": { "type": "integer" }
            },
            "ja_ad_predecessor_list": {
               "type": "array",
               "items": { "type": "integer" }
            },
            "ja_ad_successor_list": {
               "type": "array",
               "items": { "type": "integer" }
            },
            "jid_request_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "ja_ad_request_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "job_identifier_list": {
               "type": "array",
               "items": { "type": "string" }
            },
            "context": {
               "type": "array",
               "items": { "$ref": "#/$defs/name_value_string" }
            },
            "master_hard_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "slave_hard_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "master_soft_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "slave_soft_resource_list": {
               "type": "array",
               "items": { "$ref": "#/$defs/resource_request" }
            },
            "allocation_rule": { "type": "string" },
            "master_allocation_rule": { "type": "string" },
            "slave_allocation_rule": { "type": "string" }
         }
      }
   }
}